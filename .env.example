# =============================================================================
# kiosk-monitor-backend — environment template
# Copy to `.env` and replace placeholder values. Never commit real secrets.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# PostgreSQL (required for Sequelize)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kiosk_monitor
DB_USER=postgres
DB_PASSWORD=change_me
# Set to `true` for managed DBs (e.g. Supabase, RDS) that require SSL
DB_SSL=false

# --- Auth (set strong secrets in production) ---
JWT_SECRET=change-this-to-a-long-random-string
# Used for /api/auth/device-token and device JWTs
DEVICE_TOKEN_SECRET=change-this-device-token-secret

# --- CORS ---
# Single origin, or `*` to allow any origin (default if unset)
CORS_ORIGIN=http://localhost:5173
# Comma-separated list; overrides CORS_ORIGIN if you need multiple origins
# CORS_ORIGINS=http://localhost:5173,https://app.example.com

# --- AWS (avatars, presigned URLs, face enrollment & recognition) ---
# Omit or leave empty to disable S3/Rekognition features that need them.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# Rekognition collection (created at startup if missing, when id is set)
AWS_REKOGNITION_COLLECTION_ID=

# Optional: public base URL for profile images when not using presigned URLs
# PROFILE_IMAGE_PUBLIC_BASE_URL=https://your-bucket.s3.ap-south-1.amazonaws.com

# Optional: presigned URL lifetime in seconds (default 900)
# PROFILE_IMAGE_PRESIGN_SECONDS=900

# --- RBAC ---
# Set to `true` to log-but-allow forbidden actions (testing only)
# RBAC_DRY_RUN=false

# --- TURN / ICE (Flutter WebRTC clients) ---
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpassword

# --- MediaMTX CCTV playback ---
# hls    = backend HLS proxy via Pi agent (default in production — works from anywhere)
# socket = backend WebRTC offer relay + direct Pi LAN media (station LAN / dev only)
# direct = legacy GET /api/cameras/:id/webrtc-url with Pi LAN URL (dev only)
# edge   = public HTTPS edge proxy
PI_WEBRTC_PLAYBACK_MODE=hls
STREAM_TOKEN_TTL_SEC=600
MEDIAMTX_SOCKET_TIMEOUT_MS=45000
HLS_PROXY_SOCKET_TIMEOUT_MS=15000
HLS_PROXY_MAX_BODY_BYTES=8388608
MEDIAMTX_WEBRTC_SCHEME=http
MEDIAMTX_WEBRTC_PORT=8889

# Optional edge mode (PI_WEBRTC_PLAYBACK_MODE=edge) — public HTTPS proxy to Pi
# EDGE_WEBRTC_BASE_URL=https://edge.railwatch.in/webrtc
# EDGE_WEBRTC_JWT_SECRET=
# EDGE_WEBRTC_TOKEN_TTL_SEC=3600

# --- Logging ---
# DEBUG=true

# --- Tests / tooling (optional; used by test suite and scripts) ---
# BASE_URL=http://localhost:3000
# SKIP_SOCKET_E2E=1
# LIVE_SMOKE=1
# LIVE_SMOKE_URLS=https://staging.example.com,https://prod.example.com
